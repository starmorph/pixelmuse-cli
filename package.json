{
  "name": "pixelmuse",
  "version": "0.2.1",
  "description": "AI image generation from the terminal — CLI, TUI, and MCP server for text-to-image with Flux, Imagen, Recraft, and more",
  "homepage": "https://pixelmuse.studio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starmorph/pixelmuse-cli.git"
  },
  "bugs": {
    "url": "https://github.com/starmorph/pixelmuse-cli/issues"
  },
  "author": "StarMorph LLC",
  "type": "module",
  "bin": {
    "pixelmuse": "dist/cli.js",
    "pixelmuse-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "keywords": [
    "cli",
    "image-generation",
    "ai",
    "tui",
    "terminal",
    "pixelmuse",
    "text-to-image",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai-art",
    "flux",
    "imagen",
    "recraft",
    "stable-diffusion",
    "generative-ai",
    "creative-tools",
    "developer-tools",
    "api-client"
  ],
  "license": "BUSL-1.1",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.4.1",
    "env-paths": "^3.0.0",
    "ink": "^6.0.0",
    "meow": "^13.2.0",
    "open": "^10.1.0",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "keyring-node": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "phin@<3.7.1": ">=3.7.1"
    }
  }
}
